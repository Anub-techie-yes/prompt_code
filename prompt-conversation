import autogen

config_list = [{"model": "claude-sonnet-4-20250514", "api_key": "..."}]

# Orchestrator — receives the alert and plans the investigation
orchestrator = autogen.AssistantAgent(
    name="IncidentOrchestrator",
    llm_config={"config_list": config_list},
    system_message="""You are an incident commander for Spring Boot microservices.
    When given an alert, coordinate the team to investigate:
    1. Get Splunk logs for the affected service
    2. Check recent GitHub commits/deploys in the last 2 hours
    3. Look up the Confluence runbook
    4. Ask the Synthesiser to write the RCA draft
    Always include traceIds when querying logs."""
)

# Splunk specialist
splunk_agent = autogen.AssistantAgent(
    name="SplunkAgent",
    llm_config={"config_list": config_list},
    system_message="""You query Splunk for log analysis.
    Always return: top 3 error patterns, affected traceIds, 
    error rate timeline, and first occurrence timestamp."""
)

# GitHub specialist
github_agent = autogen.AssistantAgent(
    name="GitHubAgent",
    llm_config={"config_list": config_list},
    system_message="""You check GitHub for recent activity.
    For incidents, return: commits merged in last 2 hours,
    PRs touching the affected service, the committer names."""
)

# Synthesiser — writes the final RCA
synthesiser = autogen.AssistantAgent(
    name="RCASynthesiser",
    llm_config={"config_list": config_list},
    system_message="""You write Root Cause Analysis documents.
    Format: Summary / Timeline / Root cause (ranked) / 
    Immediate fix / Permanent fix / Action items table.
    Mark anything unconfirmed as [UNCONFIRMED]."""
)

# Human proxy — executes the actual API calls
user_proxy = autogen.UserProxyAgent(
    name="ToolExecutor",
    human_input_mode="NEVER",   # fully automated
    code_execution_config={"work_dir": "incident_workspace"}
)

# Group chat — agents talk to each other
groupchat = autogen.GroupChat(
    agents=[orchestrator, splunk_agent, github_agent, synthesiser, user_proxy],
    messages=[],
    max_round=12
)
manager = autogen.GroupChatManager(groupchat=groupchat, llm_config={"config_list": config_list})

# Trigger from PagerDuty webhook
def handle_alert(alert: dict):
    user_proxy.initiate_chat(
        manager,
        message=f"""
        INCIDENT ALERT
        Service: {alert['service']}
        Alert: {alert['description']}
        Time: {alert['triggered_at']}
        Environment: prod
        
        Investigate and produce an RCA draft.
        Post the result to Confluence page: Incidents/{alert['id']}
        """
    )
